APP_ENV=local
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
DATABASE_URL=postgresql://bus_booking:bus_booking@postgres:5432/bus_booking
# Keep 0 for ASGI unless a measured PgBouncer/connection-pool design says otherwise.
DATABASE_CONN_MAX_AGE=0
DATABASE_CONN_HEALTH_CHECKS=true
WEB_CONCURRENCY=2
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
JWT_SIGNING_KEY=change-me-too
MFA_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY
PLATFORM_RBAC_LEGACY_ADMIN_FALLBACK=true
CORS_ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
REGISTRATION_CHALLENGE_TTL_SECONDS=600
DEV_VERIFICATION_CODE=123456
PAYOUT_ACCOUNT_COOLING_HOURS=24
SENSITIVE_MFA_MAX_AGE_SECONDS=900
TRIP_REQUIRED_POLICY_TYPES=cancellation,payment,boarding
TRIP_DEFAULT_DURATION_HOURS=8
TRIP_RESOURCE_TURNAROUND_MINUTES=60
TRIP_MATERIAL_CHANGE_MINUTES=30
TRIP_CHANGE_RESPONSE_HOURS=24
SEAT_HOLD_TTL_SECONDS=600
PUBLIC_HOLD_RATE_LIMIT=20
PUBLIC_HOLD_RATE_WINDOW_SECONDS=60
BOOKING_MANAGE_TOKEN_KEY=REPLACE_WITH_RANDOM_SECRET
PUBLIC_BOOKING_RATE_LIMIT=12
PUBLIC_BOOKING_RATE_WINDOW_SECONDS=60

TICKET_QR_SIGNING_KEY=change-me-ticket-qr-key
PUBLIC_BOOKING_LOOKUP_RATE_LIMIT=8
PUBLIC_BOOKING_LOOKUP_RATE_WINDOW_SECONDS=300

PAYMENT_WEBHOOK_SECRET=change-me-payment-webhook-secret
ELECTRONIC_PAYMENT_ENABLED=false
DEFAULT_PAYMENT_PROVIDER_CODE=mock
PAYMENT_PROVIDER_CHECKOUT_BASE_URL=http://localhost:3000/mock-payment
CANCELLATION_QUOTE_SIGNING_KEY=replace-with-an-independent-strong-key
CANCELLATION_QUOTE_TTL_SECONDS=600
REFUND_DUAL_APPROVAL_THRESHOLD=500000.00

# Boarding/offline package security
BOARDING_OFFLINE_ENCRYPTION_KEY=replace-with-random-secret
BOARDING_OFFLINE_SIGNING_KEY=replace-with-random-secret
OFFLINE_BOARDING_PACKAGE_TTL_SECONDS=21600

# Support and operational incident SLA
SUPPORT_P0_SLA_MINUTES=5
SUPPORT_P1_SLA_MINUTES=15
SUPPORT_P2_SLA_MINUTES=60
SUPPORT_P3_SLA_MINUTES=240
SUPPORT_P4_SLA_MINUTES=1440

# Notifications
NOTIFICATION_MAX_ATTEMPTS=4
NOTIFICATION_RETRY_BASE_SECONDS=30
NOTIFICATION_RETRY_MAX_SECONDS=3600
NOTIFICATION_FORCE_FAILURE_CHANNELS=
NOTIFICATION_ESCALATION_WINDOW_HOURS=24

# Security, privacy and private file scanning
PRIVATE_UPLOAD_BASE_URL=https://upload.invalid
FILE_SCANNER_BACKEND=
FILE_SCAN_MOCK_RESULT=clean
FILE_RETENTION_DAYS=365
RISK_STEP_UP_THRESHOLD=50
RISK_MANUAL_REVIEW_THRESHOLD=70
RISK_BLOCK_THRESHOLD=90
RISK_STEP_UP_CODE=123456
RISK_STEP_UP_SIGNING_KEY=change-me

# Office subscriptions and billing
SUBSCRIPTION_ENFORCEMENT_ENABLED=true
SUBSCRIPTION_INVOICE_DUE_DAYS=7
SUBSCRIPTION_GRACE_DAYS=7
