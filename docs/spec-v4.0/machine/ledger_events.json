          "recovered_amount"
        ],
        [
          "C",
          "1040_CHARGEBACK_RECEIVABLE",
          "recovered_amount"
        ]
      ],
      "effects": [
        "رفع التجميد"
      ],
      "reversal": null
    },
    {
      "code": "CHARGEBACK_LOST_OFFICE_LIABLE",
      "when": "خسارة اعتراض والمسؤولية على المكتب",
      "source": "chargeback_decision",
      "preconditions": [
        "سبب المسؤولية موثق"
      ],
      "postings": [
        [
          "D",
          "2010_OFFICE_PAYABLE_OR_1030",
          "loss_amount"
        ],
        [
          "C",
          "1040_CHARGEBACK_RECEIVABLE",
          "loss_amount"
        ]
      ],
      "account_resolution": "يخفض payable؛ وإن لم يكف ينشئ other receivable",
      "effects": [
        "negative balance hierarchy"
      ],
      "reversal": "CHARGEBACK_DECISION_REVERSED"
    },
    {
      "code": "CHARGEBACK_LOST_PLATFORM_LIABLE",
      "when": "خسارة اعتراض بسبب فشل المنصة",
      "source": "chargeback_decision",
      "preconditions": [
        "قرار مسؤولية موثق"
      ],
      "postings": [
        [
          "D",
          "5020_FRAUD_LOSS",
          "loss_amount"
        ],
        [
          "C",
          "1040_CHARGEBACK_RECEIVABLE",
          "loss_amount"
        ]
      ],
      "effects": [
        "تسجيل خسارة منصة"
      ],
      "reversal": "CHARGEBACK_DECISION_REVERSED"
    },
    {
