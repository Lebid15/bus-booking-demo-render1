      ],
      "postings": [
        [
          "D",
          "1030_OTHER_RECEIVABLE",
          "amount"
        ],
        [
          "C",
          "4010_SUBSCRIPTION_REVENUE",
          "amount"
        ]
      ],
      "effects": [
        "invoice open"
      ],
      "reversal": "SUBSCRIPTION_CREDIT_NOTE"
    },
    {
      "code": "SUBSCRIPTION_PAID",
      "when": "قبض اشتراك المكتب",
      "source": "subscription_payment",
      "preconditions": [
        "مرجع فريد"
      ],
      "postings": [
        [
          "D",
          "1000_BANK",
          "amount"
        ],
        [
          "C",
          "1030_OTHER_RECEIVABLE",
          "amount"
        ]
      ],
      "effects": [
        "invoice paid"
      ],
      "reversal": "SUBSCRIPTION_PAYMENT_REVERSED"
    },
    {
      "code": "BAD_DEBT_WRITE_OFF",
      "when": "اعتماد شطب ذمة مكتب بعد إجراءات التحصيل",
      "source": "writeoff",
      "preconditions": [
        "اعتماد مزدوج",
        "office terminated/collection exhausted"
      ],
      "postings": [
        [
          "D",
          "5030_BAD_DEBT",
          "amount"
        ],
        [
          "C",
          "1020_OR_1030_RECEIVABLE",
          "amount"
        ]
      ],
      "effects": [
