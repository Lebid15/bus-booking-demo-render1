        [
          "D",
          "1040_CHARGEBACK_RECEIVABLE",
          "disputed_amount"
        ],
        [
          "C",
          "1010_PSP_RECEIVABLE_OR_BANK",
          "disputed_amount"
        ]
      ],
      "account_resolution": "بحسب وقت سحب المزود للمبلغ",
      "effects": [
        "تجميد المبلغ المتأثر فقط"
      ],
      "reversal": "CHARGEBACK_WON"
    },
    {
      "code": "CHARGEBACK_WON",
