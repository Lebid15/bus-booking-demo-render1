    {
      "code": "5020_FRAUD_LOSS",
      "type": "expense",
      "description_ar": "خسارة احتيال معتمدة"
    },
    {
      "code": "5030_BAD_DEBT",
      "type": "expense",
      "description_ar": "ذمة مكتب غير قابلة للتحصيل"
