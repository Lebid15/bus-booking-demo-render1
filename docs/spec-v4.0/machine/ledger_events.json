          "2020_REFUND_PAYABLE",
          "amount"
        ]
      ],
      "account_resolution": "منصة=5010؛ مكتب=خفض 2010 أو زيادة 1030",
      "effects": [
        "إنشاء payout/refund task"
      ],
      "reversal": "COMPENSATION_CANCELLED"
    },
    {
      "code": "SUBSCRIPTION_INVOICED",
      "when": "استحقاق اشتراك مكتب",
      "source": "subscription_invoice",
      "preconditions": [
