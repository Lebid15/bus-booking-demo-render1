      "source": "settlement_payment",
      "preconditions": [
        "settlement approved",
        "payout account active",
        "مرجع فريد"
      ],
      "postings": [
        [
          "D",
          "2010_OFFICE_PAYABLE",
          "payout_amount"
        ],
        [
          "C",
          "1000_BANK",
          "payout_amount"
        ]
      ],
      "effects": [
        "settlement=paid",
        "commissions=paid"
      ],
      "reversal": "OFFICE_PAYOUT_REVERSED"
    },
    {
