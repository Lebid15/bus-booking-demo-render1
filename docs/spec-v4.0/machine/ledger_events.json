  "events": [
    {
      "code": "ELECTRONIC_PAYMENT_CAPTURED",
      "when": "تأكيد مزود الدفع قبض المبلغ من الزبون",
      "source": "payment_transaction",
      "preconditions": [
        "event id فريد",
        "amount/currency مطابقان للنية",
        "الحجز غير مسترد بالكامل"
      ],
      "postings": [
        [
          "D",
          "1010_PSP_RECEIVABLE",
          "gross_amount"
        ],
        [
          "C",
          "2000_CUSTOMER_FUNDS",
          "gross_amount"
        ]
      ],
      "effects": [
        "booking.paid_amount += gross",
        "payment_intent=succeeded"
      ],
      "reversal": "ELECTRONIC_PAYMENT_REVERSED"
    },
    {
      "code": "PSP_FEE_RECOGNIZED",
      "when": "استلام كشف/حدث رسوم المزود",
      "source": "provider_fee_event",
      "preconditions": [
        "fee>=0",
        "مرجع مزود فريد"
      ],
      "postings": [
        [
          "D",
          "5000_PAYMENT_PROVIDER_FEES",
          "fee_amount"
        ],
        [
          "C",
          "1010_PSP_RECEIVABLE",
          "fee_amount"
        ]
      ],
      "effects": [
        "ربط الرسوم بالحركة"
      ],
      "reversal": "PSP_FEE_REVERSED"
    },
    {
      "code": "PSP_FUNDS_SETTLED",
      "when": "تحويل المزود صافي الأموال إلى حساب المنصة",
      "source": "provider_settlement",
      "preconditions": [
        "مطابقة batch",
        "لا فرق غير مفسر"
      ],
      "postings": [
        [
          "D",
          "1000_BANK",
          "settled_amount"
        ],
        [
          "C",
          "1010_PSP_RECEIVABLE",
          "settled_amount"
        ]
      ],
      "effects": [
        "إغلاق batch أو تسجيل فرق للمصالحة"
      ],
      "reversal": "PSP_SETTLEMENT_REVERSED"
    },
    {
      "code": "SERVICE_COMPLETED_ELECTRONIC",
      "when": "الحجز مؤهل ماليًا بعد اكتمال الرحلة/No-show حسب السياسة",
      "source": "booking_completion",
      "preconditions": [
        "commission snapshot ثابت",
        "لا refund pending على المبلغ نفسه"
      ],
      "postings": [
        [
          "D",
          "2000_CUSTOMER_FUNDS",
          "recognized_gross"
        ],
        [
          "C",
          "2010_OFFICE_PAYABLE",
          "office_net"
        ],
        [
          "C",
          "4000_COMMISSION_REVENUE",
          "commission_amount"
        ]
      ],
      "formula": "recognized_gross = office_net + commission_amount",
      "effects": [
        "commission=earned",
        "booking eligible for settlement"
      ],
      "reversal": "SERVICE_RECOGNITION_REVERSED"
    },
    {
      "code": "COMMISSION_EARNED_DIRECT",
      "when": "اكتمال خدمة حجز دُفع مباشرة للمكتب",
      "source": "booking_completion",
      "preconditions": [
        "الدفع المباشر verified",
        "commission snapshot ثابت"
      ],
      "postings": [
        [
          "D",
          "1020_OFFICE_COMMISSION_RECEIVABLE",
          "commission_amount"
        ],
        [
          "C",
          "4000_COMMISSION_REVENUE",
          "commission_amount"
        ]
      ],
      "effects": [
        "commission=earned",
        "إدراجها في المقاصة/فاتورة المكتب"
      ],
      "reversal": "COMMISSION_REVERSED_DIRECT"
    },
    {
      "code": "DIRECT_COMMISSION_NETTED",
      "when": "خصم عمولة مستحقة على المكتب من مستحقاته الإلكترونية",
      "source": "settlement_item",
      "preconditions": [
        "نفس المكتب والعملة",
        "receivable متاح"
      ],
      "postings": [
        [
          "D",
          "2010_OFFICE_PAYABLE",
          "netted_amount"
        ],
        [
          "C",
          "1020_OFFICE_COMMISSION_RECEIVABLE",
          "netted_amount"
        ]
      ],
      "effects": [
        "إضافة عنصر مقاصة للتسوية"
      ],
      "reversal": "DIRECT_COMMISSION_NETTING_REVERSED"
    },
    {
      "code": "OFFICE_COMMISSION_PAID",
      "when": "سداد المكتب عمولة مباشرة للمنصة",
      "source": "office_payment",
      "preconditions": [
        "مرجع قبض مثبت"
      ],
      "postings": [
        [
          "D",
          "1000_BANK",
          "amount"
        ],
        [
          "C",
          "1020_OFFICE_COMMISSION_RECEIVABLE",
          "amount"
        ]
      ],
      "effects": [
        "خفض ذمة المكتب"
      ],
      "reversal": "OFFICE_COMMISSION_PAYMENT_REVERSED"
    },
    {
      "code": "REFUND_APPROVED_PRE_SERVICE",
      "when": "اعتماد استرداد قبل استحقاق الإيراد",
      "source": "refund",
      "preconditions": [
        "المبلغ ضمن CUSTOMER_FUNDS",
        "لا chargeback مزدوج"
      ],
      "postings": [
        [
          "D",
          "2000_CUSTOMER_FUNDS",
          "refund_amount"
        ],
        [
          "C",
          "2020_REFUND_PAYABLE",
          "refund_amount"
        ]
      ],
      "effects": [
        "حجز المبلغ للاسترداد"
      ],
      "reversal": "REFUND_APPROVAL_CANCELLED"
    },
    {
      "code": "REFUND_EXECUTED",
      "when": "تأكيد خروج الاسترداد إلى وسيلة الدفع الأصلية",
      "source": "refund_transaction",
      "preconditions": [
        "refund approved",
        "provider reference فريد"
      ],
      "postings": [
        [
          "D",
          "2020_REFUND_PAYABLE",
          "refund_amount"
        ],
        [
          "C",
          "1000_BANK_OR_PSP",
          "refund_amount"
        ]
      ],
      "account_resolution": "استخدم 1010 إن خصم المزود قبل التسوية، وإلا 1000",
      "effects": [
        "refund=succeeded",
        "booking.refunded_amount += amount"
      ],
      "reversal": "REFUND_EXECUTION_REVERSED"
    },
    {
      "code": "REFUND_AFTER_RECOGNITION_ELECTRONIC",
