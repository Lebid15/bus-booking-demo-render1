      "preconditions": [
        "تحديد من يتحمل الجزء وفق policy/causality"
      ],
      "postings": [
        [
          "D",
          "2010_OFFICE_PAYABLE",
          "office_share"
        ],
        [
          "D",
          "4090_COMMISSION_REVERSAL",
          "platform_share"
        ],
        [
          "C",
          "2020_REFUND_PAYABLE",
          "refund_amount"
        ]
      ],
      "formula": "refund_amount = office_share + platform_share",
      "effects": [
        "commission adjusted",
        "تخفيض صافي المكتب"
      ],
      "reversal": "POST_RECOGNITION_REFUND_CANCELLED"
    },
    {
      "code": "REFUND_AFTER_RECOGNITION_DIRECT",
      "when": "إلغاء/استرداد حجز كان المال عند المكتب",
      "source": "refund_approval",
      "preconditions": [
        "المكتب مسؤول عن رد العميل أو إثبات التنفيذ"
      ],
      "postings": [
        [
          "D",
          "4090_COMMISSION_REVERSAL",
          "commission_reversal"
        ],
        [
          "C",
          "1020_OFFICE_COMMISSION_RECEIVABLE",
          "commission_reversal"
        ]
      ],
      "effects": [
        "تخفيض عمولة المكتب؛ الاسترداد نفسه خارج حساب المنصة ويثبت تشغيليًا"
      ],
      "reversal": "DIRECT_REFUND_REVERSAL_CANCELLED"
    },
    {
      "code": "RESERVE_WITHHELD",
      "when": "حجز احتياطي مخاطر من مستحق مكتب",
      "source": "reserve_rule",
      "preconditions": [
        "حد معتمد",
        "المبلغ <= office payable"
      ],
      "postings": [
        [
          "D",
          "2010_OFFICE_PAYABLE",
          "reserve_amount"
        ],
        [
          "C",
          "2030_RESERVE_HELD",
          "reserve_amount"
        ]
      ],
      "effects": [
        "settlement reserve item"
      ],
      "reversal": "RESERVE_RELEASED"
