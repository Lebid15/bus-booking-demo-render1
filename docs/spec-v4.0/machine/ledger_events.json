      ],
      "postings": [
        [
          "D",
          "2030_RESERVE_HELD",
          "reserve_amount"
        ],
        [
          "C",
          "2010_OFFICE_PAYABLE",
          "reserve_amount"
        ]
      ],
      "effects": [
        "إتاحة المبلغ للتسوية"
      ],
      "reversal": "RESERVE_REWITHHELD"
    },
    {
